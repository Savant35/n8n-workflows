    {
      "parameters": {
        "inputText": "=Sender Email: {{ $json.headers.from }}\nSender Name: {{ $json.from.value[0].address }}\nSubject: {{$json.headers.subject }}\nEmail Body: {{ $json.text }}",
        "categories": {
          "categories": [
            {
              "category": "SUBSCRIPTION",
              "description": "=Analyze the email (Subject: {{ $json.subject }}, Body: {{ $json.text }}, Sender: {{  $json.headers.from  }}). Only classify the message as 'SUBSCRIPTIONS' if it is a bulk, transactional, or recurring paid service email (e.g., Amazon prime, youtube, chatgpt).\n\nClassify as Subscritions if it seems like its a subscription"
            },
            {
              "category": "ACTION_REQUIRED",
              "description": "Analyze the email (Subject: {{ $json.subject }}, Body: {{ $json.text }}, Sender: {{ $json.from_email }}). Classify the message as 'SUBSCRIPTIONS' if it is a bulk, transactional, or recurring paid service email (e.g., Amazon prime, youtube, chatgpt);"
            },
            {
              "category": "JOB_INTERVIEW",
              "description": "=Analyze the email (Subject: {{ $json.subject }}, Body: {{ $json.text }}, Sender: {{ $json.headers.from }}). Only classify the message as 'JOB_INTERVIEW' if it is personal communication from a recruiter or hiring manager regarding interview scheduling/confirmation, follow-up after an interview, or providing a link/instructions for a mandatory online assessment."
            },
            {
              "category": "JOB_UPDATE",
              "description": "=Analyze the email (Subject: {{ $json.subject }}, Body: {{ $json.text }}, Sender: {{ $json.headers.from }}). Only classify the message as 'JOB_UPDATE' if it is a general, non-urgent status update related to a job application, such as initial application confirmation, rejection letters, or mass communication about the job status."
            },
            {
              "category": "IMPORTANT_GENERAL",
              "description": "=Analyze the email (Subject: {{ $json.subject }}, Body: {{ $json.text }}, Sender: {{ $json.headers.from }}). Only classify the message as 'Important' if it is a high-value, non-urgent, personal email, such as official financial statements, important documents, or substantive non-job correspondence from professional contacts."
            },
            {
              "category": "FINANCIAL_STATEMENT",
              "description": "=Analyze the email (Subject: {{ $json.subject }}, Body: {{ $json.text }}, Sender: {{ $json.headers.from }}). Only classify the message as 'FINANCIAL_STATEMENT' if it is an official, recurring document like a bank statement, credit card statement, investment statement (e.g., Robinhood), or official yearly tax document.\n\nClassify any message you think is a Finactial Statement with the Tag FINANCIAL_STATEMENT"
            }
          ]
        },
        "options": {}
